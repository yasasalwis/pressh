# ─────────────────────────────────────────────────────────────
# Pressh environment configuration. Copy to `.env` and fill in.
# Never commit your real `.env`.
# ─────────────────────────────────────────────────────────────

# REQUIRED in production — 32-byte key (hex/base64) or a passphrase.
# Seals the secrets vault (AES-256-GCM): SMTP credentials and any
# plugin-requested secrets. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# In dev it is optional; without it, storing SMTP credentials in Studio
# Settings is disabled (the screen reports this).
PRESSH_MASTER_KEY=

# REQUIRED in production — 32-byte hex used to sign CSRF tokens.
PRESSH_CSRF_SECRET=

# Storage roots (filesystem adapter, the default).
PRESSH_CONTENT_ROOT=./data/content
PRESSH_MEDIA_ROOT=./data/media

# Storage backend selection is NOT an env var. The default is the filesystem.
# Switch to SQLite / PostgreSQL / MySQL / MongoDB from Studio → Database: it
# copies your data, verifies it, backs up the old store, then restarts Pressh on
# the new backend. The choice is persisted in `<data>/storage.json` and the
# connection string is sealed in the vault (so PRESSH_MASTER_KEY is required for
# database backends). A process supervisor (Docker `restart: unless-stopped`,
# systemd `Restart=always`, pm2) must be configured so the cutover restart is
# applied automatically.
#
# Optional override for where the active-storage config file lives
# (defaults next to PRESSH_CONTENT_ROOT, e.g. ./data/storage.json):
# PRESSH_STORAGE_CONFIG=./data/storage.json

# Ports.
PRESSH_STUDIO_PORT=4000
PRESSH_SITE_PORT=3000

# Optional: directory of user-installed (third-party) plugins to load at boot.
# PRESSH_PLUGINS_DIR=./plugins

# First-party built-in plugins shipped with Pressh (DB, Inventory, Forms, SEO,
# Analytics). Defaults to ./builtins. All ship DISABLED — enable the ones you
# need from Studio → Plugins so the app stays lean. Disabled plugins run no
# worker at all.
# PRESSH_BUILTINS_DIR=./builtins

# Set to "production" to require TLS, signed plugins, and PRESSH_MASTER_KEY.
NODE_ENV=development
