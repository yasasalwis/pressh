# ─────────────────────────────────────────────────────────────
# Pressh environment configuration. Copy to `.env` and fill in.
# Never commit your real `.env`.
#
# The build and both apps load this file automatically when run from the project
# root. Real environment variables always take precedence over it, and a missing
# file is a no-op — so `.env` is a dev convenience; production sets vars directly.
# ─────────────────────────────────────────────────────────────

# REQUIRED in production — 32-byte key (hex/base64) or a passphrase.
# Seals the secrets vault (AES-256-GCM): SMTP credentials and any
# plugin-requested secrets. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# In dev it is optional; without it, storing SMTP credentials in Studio
# Settings is disabled (the screen reports this).
PRESSH_MASTER_KEY=

# REQUIRED in production — 32-byte hex used to sign CSRF tokens.
PRESSH_CSRF_SECRET=

# Storage roots (filesystem adapter, the default).
PRESSH_CONTENT_ROOT=./data/content
PRESSH_MEDIA_ROOT=./data/media

# Storage backend selection is NOT an env var. The default is the filesystem.
# Switch to SQLite / PostgreSQL / MySQL / MongoDB from Studio → Database: it
# copies your data, verifies it, backs up the old store, then restarts Pressh on
# the new backend. The choice is persisted in `<data>/storage.json` and the
# connection string is sealed in the vault (so PRESSH_MASTER_KEY is required for
# database backends). A process supervisor (Docker `restart: unless-stopped`,
# systemd `Restart=always`, pm2) must be configured so the cutover restart is
# applied automatically.
#
# Optional override for where the active-storage config file lives
# (defaults next to PRESSH_CONTENT_ROOT, e.g. ./data/storage.json):
# PRESSH_STORAGE_CONFIG=./data/storage.json

# Ports.
PRESSH_STUDIO_PORT=4000
PRESSH_SITE_PORT=3000

# Optional: directory of user-installed (third-party) plugins to load at boot.
# PRESSH_PLUGINS_DIR=./plugins

# First-party built-in plugins shipped with Pressh (DB, Inventory, Forms, SEO,
# Analytics). Defaults to ./builtins. All ship DISABLED — enable the ones you
# need from Studio → Plugins so the app stays lean. A disabled plugin runs no
# worker; an enabled one spawns its worker LAZILY on first use and is torn down
# again after an idle period (see the tuning section below).
# PRESSH_BUILTINS_DIR=./builtins

# Set to "production" to require TLS, signed plugins, and PRESSH_MASTER_KEY.
NODE_ENV=development

# ─────────────────────────────────────────────────────────────
# Performance / low-memory tuning (optional). Defaults target a 512 MB VM.
# The Docker image already sets NODE_OPTIONS / MALLOC_ARENA_MAX / UV_THREADPOOL_SIZE;
# the vars below tune the app's own memory behaviour and apply everywhere.
# ─────────────────────────────────────────────────────────────
#
# Per-plugin worker heap cap (MB). Lower = more plugins fit a small box; higher
# = headroom for heavy plugins. Default 64.
# PRESSH_PLUGIN_MAX_MEMORY_MB=64
#
# Idle timeout (ms) before an enabled plugin's worker is torn down to reclaim
# memory (it respawns on the next request). 0 keeps workers resident. Default 300000 (5 min).
# PRESSH_PLUGIN_IDLE_MS=300000
#
# Public render-cache budget in BYTES (not entry count). Caps the HTML the Site
# holds in memory. Default 25165824 (24 MB).
# PRESSH_RENDER_CACHE_MAX_BYTES=25165824
#
# Scheduled backups (Studio only — the Site has no scheduler). Set the directory
# to enable automatic recurring backups of content, media, the secrets vault, and
# the audit log. Point it at a MOUNTED OFFSITE VOLUME (NFS / separate disk /
# rclone or S3 FUSE mount) for offsite disaster recovery. The dir holds the vault
# + audit log — keep it on restricted/encrypted storage. Manage from Studio →
# System → Backups (back up now, restore drill). Unset = no scheduled backups.
# PRESSH_BACKUP_DIR=/data/backups
# PRESSH_BACKUP_INTERVAL_MS=86400000   # interval between runs (default 24h)
# PRESSH_BACKUP_KEEP=7                  # timestamped backups to retain (default 7)
#
# Password hashing (argon2id) cost. Defaults are OWASP minimums tuned for small
# VMs (~19 MiB, 2 iterations, single lane). Raise on roomier/security-sensitive
# hosts. Existing password hashes keep verifying after a change.
# PRESSH_ARGON2_MEMORY_KIB=19456
# PRESSH_ARGON2_TIME_COST=2
# PRESSH_ARGON2_PARALLELISM=1
