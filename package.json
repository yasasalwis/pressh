{
  "name": "pressh",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Pressh — secure-by-default, no-code, self-hosted CMS",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "packages/*",
    "adapters/*",
    "apps/*"
  ],
  "scripts": {
    "build:packages": "tsc -b",
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "clean": "tsc -b --clean",
    "pretest": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "optionalDependencies": {
    "@emnapi/core": "1.10.0",
    "@emnapi/runtime": "1.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.0.0",
    "vite": "8.0.13",
    "vitest": "4.1.7"
  }
}
