{
  "name": "pressh",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Pressh — secure-by-default, no-code, self-hosted CMS",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "packages/*",
    "adapters/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc -b && npm run build:admin && npm run build:panels && npm run sign:builtins && vite build --config apps/site/vite.config.ts",
    "build:admin": "node scripts/build-admin.mjs",
    "build:panels": "node scripts/build-panels.mjs",
    "build:hello": "pressh-build-panel plugins/hello/panel-src/main.tsx --out plugins/hello/panel.html",
    "sign:builtins": "node scripts/sign-builtins.mjs",
    "typecheck": "tsc -b",
    "clean": "tsc -b --clean",
    "tests": "tsc -b && vitest run",
    "test": "npm run tests",
    "test:watch": "vitest",
    "lint": "eslint .",
    "start": "tsc -b && node scripts/run.mjs",
    "seed": "node apps/studio/dist/seed-cli.js",
    "reseed:pages": "node apps/studio/dist/reseed-prebuilt.js",
    "studio": "node apps/studio/dist/server.js",
    "site": "node apps/site/dist/server.js"
  },
  "devDependencies": {
    "@emnapi/core": "1.10.0",
    "@emnapi/runtime": "1.10.0",
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "esbuild": "0.28.0",
    "eslint": "^9.0.0",
    "globals": "^14.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.0.0",
    "vite": "8.0.13",
    "vitest": "4.1.7"
  }
}
