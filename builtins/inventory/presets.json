[
  {
    "id": "product-grid",
    "name": "Product Grid",
    "icon": "🛍",
    "category": "Store",
    "description": "Grid of published products with image, name, price and an add-to-cart button",
    "template": [
      {
        "id": "pg-sec",
        "type": "section",
        "styles": {
          "base": {
            "default": {
              "paddingTop": "4rem",
              "paddingBottom": "4rem"
            }
          }
        },
        "children": [
          {
            "id": "pg-cont",
            "type": "container",
            "styles": {
              "base": {
                "default": {
                  "paddingLeft": "1.5rem",
                  "paddingRight": "1.5rem"
                }
              }
            },
            "children": [
              {
                "id": "pg-h",
                "type": "heading",
                "props": {
                  "text": "Shop",
                  "level": 2
                },
                "styles": {
                  "base": {
                    "default": {
                      "fontSize": "2rem",
                      "fontWeight": "800",
                      "color": "token:colorText",
                      "marginBottom": "1.5rem"
                    }
                  }
                }
              },
              {
                "id": "pg-list",
                "type": "collectionList",
                "props": {
                  "source": "inventory:products",
                  "limit": 8,
                  "emptyText": "No products available yet."
                },
                "styles": {
                  "base": {
                    "default": {
                      "gridTemplateColumns": "repeat(4,1fr)",
                      "gap": "1.5rem"
                    }
                  },
                  "mobile": {
                    "default": {
                      "gridTemplateColumns": "repeat(2,1fr)"
                    }
                  }
                },
                "children": [
                  {
                    "id": "pg-card",
                    "type": "column",
                    "styles": {
                      "base": {
                        "default": {
                          "background": "#ffffff",
                          "borderWidth": "1px",
                          "borderStyle": "solid",
                          "borderColor": "#e2e8f0",
                          "borderRadius": "14px",
                          "paddingTop": "1rem",
                          "paddingBottom": "1rem",
                          "paddingLeft": "1rem",
                          "paddingRight": "1rem",
                          "gap": "0.6rem"
                        }
                      }
                    },
                    "children": [
                      {
                        "id": "pg-img",
                        "type": "image",
                        "props": {
                          "src": "",
                          "alt": ""
                        },
                        "bindings": {
                          "src": {
                            "field": "image"
                          },
                          "alt": {
                            "field": "name"
                          }
                        },
                        "styles": {
                          "base": {
                            "default": {
                              "width": "100%",
                              "borderRadius": "10px"
                            }
                          }
                        }
                      },
                      {
                        "id": "pg-name",
                        "type": "heading",
                        "props": {
                          "text": "Product",
                          "level": 3
                        },
                        "bindings": {
                          "text": {
                            "field": "name"
                          }
                        },
                        "styles": {
                          "base": {
                            "default": {
                              "fontSize": "1.05rem",
                              "fontWeight": "700",
                              "color": "token:colorText"
                            }
                          }
                        }
                      },
                      {
                        "id": "pg-price",
                        "type": "text",
                        "props": {
                          "text": "$0.00"
                        },
                        "bindings": {
                          "text": {
                            "field": "priceLabel"
                          }
                        },
                        "styles": {
                          "base": {
                            "default": {
                              "color": "token:colorPrimary",
                              "fontWeight": "700"
                            }
                          }
                        }
                      },
                      {
                        "id": "pg-add",
                        "type": "addToCart",
                        "props": {
                          "label": "Add to cart"
                        },
                        "bindings": {
                          "productId": {
                            "field": "id"
                          }
                        },
                        "styles": {
                          "base": {
                            "default": {
                              "background": "token:colorPrimary",
                              "color": "#ffffff",
                              "marginTop": "0.25rem"
                            },
                            "hover": {
                              "opacity": "0.9"
                            }
                          }
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  {
    "id": "featured-products",
    "name": "Featured Products",
    "icon": "⭐",
    "category": "Store",
    "description": "Highlight a few products in a compact row",
    "template": [
      {
        "id": "fp-sec",
        "type": "section",
        "styles": {
          "base": {
            "default": {
              "paddingTop": "4rem",
              "paddingBottom": "4rem",
              "background": "#f8fafc"
            }
          }
        },
        "children": [
          {
            "id": "fp-cont",
            "type": "container",
            "styles": {
              "base": {
                "default": {
                  "paddingLeft": "1.5rem",
                  "paddingRight": "1.5rem"
                }
              }
            },
            "children": [
              {
                "id": "fp-h",
                "type": "heading",
                "props": {
                  "text": "Featured",
                  "level": 2
                },
                "styles": {
                  "base": {
                    "default": {
                      "fontSize": "1.75rem",
                      "fontWeight": "800",
                      "color": "token:colorText",
