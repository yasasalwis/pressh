                  },
                  "mobile": {
                    "default": {
                      "gridTemplateColumns": "1fr"
                    }
                  }
                },
                "children": [
                  {
                    "id": "fp-card",
                    "type": "column",
                    "styles": {
                      "base": {
                        "default": {
                          "alignItems": "center",
                          "textAlign": "center",
                          "gap": "0.5rem"
                        }
                      }
                    },
                    "children": [
                      {
                        "id": "fp-img",
                        "type": "image",
                        "props": {
                          "src": "",
                          "alt": ""
                        },
                        "bindings": {
                          "src": {
                            "field": "image"
                          },
                          "alt": {
                            "field": "name"
                          }
                        },
                        "styles": {
                          "base": {
                            "default": {
                              "width": "100%",
                              "borderRadius": "12px"
                            }
                          }
                        }
                      },
                      {
                        "id": "fp-name",
                        "type": "heading",
                        "props": {
                          "text": "Product",
                          "level": 3
                        },
                        "bindings": {
                          "text": {
                            "field": "name"
                          }
                        },
                        "styles": {
                          "base": {
                            "default": {
                              "fontSize": "1.1rem",
                              "fontWeight": "700",
                              "color": "token:colorText"
                            }
                          }
                        }
                      },
                      {
                        "id": "fp-price",
                        "type": "text",
                        "props": {
                          "text": "$0.00"
                        },
                        "bindings": {
                          "text": {
                            "field": "priceLabel"
                          }
                        },
                        "styles": {
                          "base": {
                            "default": {
                              "color": "token:colorPrimary",
                              "fontWeight": "700"
                            }
                          }
                        }
                      },
                      {
                        "id": "fp-add",
                        "type": "addToCart",
                        "props": {
                          "label": "Add to cart"
                        },
                        "bindings": {
                          "productId": {
                            "field": "id"
                          }
                        },
                        "styles": {
                          "base": {
                            "default": {
                              "background": "token:colorPrimary",
                              "color": "#ffffff"
                            },
                            "hover": {
                              "opacity": "0.9"
                            }
                          }
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  {
    "id": "cart-button",
    "name": "Cart Button",
    "icon": "🛒",
    "category": "Store",
    "description": "Mini-cart button showing the live item count (place in a header)",
    "template": [
      {
        "id": "cb",
        "type": "commerce",
        "props": {
          "view": "cartButton",
          "label": "Cart"
        },
        "styles": {
          "base": {
            "default": {
              "display": "inline-flex",
              "alignItems": "center",
              "gap": "0.4rem",
              "paddingTop": "0.5rem",
              "paddingBottom": "0.5rem",
              "paddingLeft": "1rem",
              "paddingRight": "1rem",
              "borderWidth": "1px",
              "borderStyle": "solid",
              "borderColor": "token:colorPrimary",
              "borderRadius": "999px",
              "color": "token:colorPrimary",
              "fontWeight": "700"
            }
          }
        }
      }
    ]
  },
  {
    "id": "cart",
    "name": "Shopping Cart",
    "icon": "🧺",
    "category": "Store",
    "description": "Full cart with line items, quantities and totals",
    "template": [
      {
        "id": "ct-sec",
        "type": "section",
        "styles": {
          "base": {
            "default": {
              "paddingTop": "3rem",
              "paddingBottom": "4rem"
            }
          }
        },
        "children": [
          {
            "id": "ct-cont",
            "type": "container",
            "styles": {
              "base": {
                "default": {
                  "paddingLeft": "1.5rem",
                  "paddingRight": "1.5rem",
                  "maxWidth": "760px"
                }
              }
            },
            "children": [
              {
                "id": "ct-h",
                "type": "heading",
                "props": {
                  "text": "Your cart",
                  "level": 1
                },
                "styles": {
                  "base": {
                    "default": {
                      "fontSize": "2rem",
                      "fontWeight": "800",
                      "color": "token:colorText",
                      "marginBottom": "1.5rem"
                    }
                  }
                }
              },
              {
                "id": "ct-body",
                "type": "commerce",
                "props": {
                  "view": "cart"
                }
              }
            ]
          }
        ]
      }
    ]
  },
  {
    "id": "checkout",
    "name": "Checkout",
    "icon": "💳",
    "category": "Store",
    "description": "Cart summary plus the customer details form that places the order",
    "template": [
      {
        "id": "co-sec",
        "type": "section",
        "styles": {
          "base": {
            "default": {
              "paddingTop": "3rem",
              "paddingBottom": "4rem"
            }
          }
        },
        "children": [
          {
            "id": "co-cont",
            "type": "container",
            "styles": {
              "base": {
                "default": {
                  "paddingLeft": "1.5rem",
                  "paddingRight": "1.5rem",
                  "maxWidth": "760px"
                }
              }
            },
            "children": [
              {
                "id": "co-h",
                "type": "heading",
                "props": {
                  "text": "Checkout",
                  "level": 1
                },
                "styles": {
                  "base": {
                    "default": {
                      "fontSize": "2rem",
                      "fontWeight": "800",
                      "color": "token:colorText",
                      "marginBottom": "1.5rem"
                    }
                  }
                }
              },
              {
                "id": "co-body",
                "type": "commerce",
                "props": {
                  "view": "checkout"
                }
              }
            ]
          }
        ]
      }
    ]
  },
  {
    "id": "add-to-cart",
    "name": "Add to Cart Button",
    "icon": "➕",
    "category": "Store",
    "description": "A standalone add-to-cart button (set the product id in its properties)",
    "template": [
      {
        "id": "atc",
        "type": "addToCart",
        "props": {
          "label": "Add to cart",
          "productId": ""
        },
        "styles": {
          "base": {
            "default": {
              "background": "token:colorPrimary",
              "color": "#ffffff",
              "paddingTop": "0.8rem",
              "paddingBottom": "0.8rem",
              "paddingLeft": "1.6rem",
              "paddingRight": "1.6rem",
              "borderRadius": "10px",
              "fontWeight": "700"
            },
            "hover": {
              "opacity": "0.9"
            }
          }
        }
      }
    ]
  }
]
