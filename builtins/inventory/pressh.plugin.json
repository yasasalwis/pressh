{
  "name": "inventory",
  "version": "2.0.0",
  "main": "index.mjs",
  "capabilities": [
    "storage.read:inventory_items",
    "storage.write:inventory_items",
    "storage.read:inventory_categories",
    "storage.write:inventory_categories",
    "storage.read:inventory_stock_movements",
    "storage.write:inventory_stock_movements",
    "storage.read:inventory_settings",
    "storage.write:inventory_settings",
    "storage.read:inventory_orders",
    "storage.write:inventory_orders",
    "storage.read:inventory_returns",
    "storage.write:inventory_returns",
    "storage.read:inventory_payments",
    "storage.write:inventory_payments",
    "storage.read:inventory_counters",
    "storage.write:inventory_counters"
  ],
  "endpoints": [
    {
      "method": "GET",
      "path": "/items",
      "handler": "publicItems"
    },
    {
      "method": "POST",
      "path": "/products",
      "handler": "feed"
    },
    {
      "method": "POST",
      "path": "/cart",
      "handler": "cartPreview"
    },
    {
      "method": "POST",
      "path": "/checkout",
      "handler": "checkout"
    }
  ],
  "panel": { "title": "Inventory", "entry": "panel.html" },
  "designerPresets": "presets.json",
  "panelActions": [
    "summary",
    "listItems",
    "getItem",
    "saveItem",
    "removeItem",
    "listCategories",
    "saveCategory",
    "removeCategory",
    "adjustStock",
    "listMovements",
    "getSettings",
    "saveSettings",
    "createOrder",
    "listOrders",
    "getOrder",
    "updateOrderStatus",
    "fulfillOrder",
    "cancelOrder",
    "recordPayment",
    "refundPayment",
    "listPayments",
    "createReturn",
    "listReturns",
    "getReturn",
    "updateReturnStatus",
    "processReturn"
  ]
}
